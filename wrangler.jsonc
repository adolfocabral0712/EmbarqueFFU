{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "embarqueffu",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
